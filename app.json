{
  "expo": {
    "name": "lucid",
    "slug": "lucid",
    "scheme": "lucid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/icons/app-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.lucid"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5B5FC7",
        "foregroundImage": "./src/icons/adaptive-icon.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.anonymous.lucid"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Satoshi-Light.otf",
            "./assets/fonts/Satoshi-Regular.otf",
            "./assets/fonts/Satoshi-Medium.otf",
            "./assets/fonts/Satoshi-Bold.otf",
            "./assets/fonts/Satoshi-Black.otf",
            "./assets/fonts/LexendDeca-Regular.ttf"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-router",
      "expo-secure-store"
    ]
  }
}
